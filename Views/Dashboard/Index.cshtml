@{
    ViewBag.Title = "Dashboard";
}

<div class="dashboard-container">

    <header class="topbar">
        <div>
            <h2>Good Morning, Admin 👋</h2>
            <p>Welcome to Clothing Management System</p>
        </div>

        <input type="text" placeholder="Search..." class="search-box" />
    </header>

    <section class="hero">

        <div class="hero-text">
            <h1>Manage.<br>Track.<br>Grow.</h1>

            <p>Everything in Style.</p>

            <button>View Reports</button>

        </div>

        <div class="hero-image">

            <div class="placeholder">
                Clothing Banner
            </div>

        </div>

    </section>

    <section class="cards">

        <div class="card">
            <h3>Total Products</h3>
            <h1>632</h1>
        </div>

        <div class="card">
            <h3>Categories</h3>
            <h1>26</h1>
        </div>

        <div class="card">
            <h3>Low Stock</h3>
            <h1>14</h1>
        </div>

        <div class="card">
            <h3>Out Of Stock</h3>
            <h1>4</h1>
        </div>

    </section>

</div>