@model ClotheManagementSystem.Models.DashboardViewModel

@{
    ViewBag.Title = "Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="dashboard-wrapper">

    <!-- HERO -->

    <section class="hero-section">

        <div class="hero-left">

            <span class="hero-badge">
                CLOTHING MANAGEMENT
            </span>

            @{
                string greet = "Good Morning";

                if (DateTime.Now.Hour >= 12 && DateTime.Now.Hour < 17)
                {
                    greet = "Good Afternoon";
                }
                else if (DateTime.Now.Hour >= 17)
                {
                    greet = "Good Evening";
                }
            }

            <h1>
                @greet,
                <span>Admin</span>
                <span class="wave">👋</span>
            </h1>

            <p>
                Monitor inventory, products, orders and business performance
                from one intelligent dashboard built for modern retail.
            </p>

            <div class="hero-info">

                <div class="hero-item">
                    <h3>@DateTime.Now.ToString("dddd")</h3>
                    <span>Today</span>
                </div>

                <div class="hero-item">
                    <h3>@DateTime.Now.ToString("dd MMM yyyy")</h3>
                    <span>Date</span>
                </div>

                <div class="hero-item">
                    <h3>Online</h3>
                    <span>System Status</span>
                </div>

            </div>

        </div>

        <div class="hero-buttons">

            <a href="@Url.Action("Create","Product")"
               class="btn-primary">

                <i class="ri-add-line"></i>

                Add Product

            </a>

            <a href="@Url.Action("Index","Product")"
               class="btn-secondary">

                <i class="ri-list-check-2-line"></i>

                View Products

            </a>

        </div>

    </section>



    <!-- STATS -->

    <section class="stats-grid">

        <div class="stat-card">

            <div class="stat-top">

                <span>Total Products</span>

                <i class="ri-shirt-line"></i>

            </div>

            <h2>

                @Model.TotalProducts

            </h2>

            <small>

                Registered Products

            </small>

        </div>



        <div class="stat-card">

            <div class="stat-top">

                <span>Categories</span>

                <i class="ri-apps-2-line"></i>

            </div>

            <h2>

                @Model.TotalCategories

            </h2>

            <small>

                Active Categories

            </small>

        </div>



        <div class="stat-card warning">

            <div class="stat-top">

                <span>Low Stock</span>

                <i class="ri-alarm-warning-line"></i>

            </div>

            <h2>

                @Model.LowStockProducts

            </h2>

            <small>

                Needs Attention

            </small>

        </div>



        <div class="stat-card success">

            <div class="stat-top">

                <span>Inventory Value</span>

                <i class="ri-funds-box-line"></i>

            </div>

            <h2>

                ₹@Model.TotalRevenue

            </h2>

            <small>

                Current Value

            </small>

        </div>

    </section>



    <!-- MAIN GRID -->

    <section class="main-grid">

        <!-- LEFT -->

        <div class="left-column">



            <!-- ANALYTICS -->

            <div class="glass-card analytics-card">

                <div class="card-header">

                    <div>

                        <h3>

                            Inventory Analytics

                        </h3>

                        <span>

                            Live business insights

                        </span>

                    </div>

                </div>

                <div class="chart-placeholder">

                    <div class="chart-circle">

                        <i class="ri-line-chart-line"></i>

                    </div>

                    <div style="padding:20px;">

                        <p><strong>Total Products :</strong> @Model.TotalProducts</p>

                        <p><strong>Total Categories :</strong> @Model.TotalCategories</p>

                        <p><strong>Low Stock :</strong> @Model.LowStockProducts</p>

                        <p><strong>Total Revenue :</strong> ₹@Model.TotalRevenue</p>

                    </div>

                    <p>

                        After SQL integration, revenue, stock trend and category analytics will automatically load.

                    </p>

                </div>

            </div>



            <!-- RECENT PRODUCTS -->

            <div class="glass-card">

                <div class="card-header">

                    <h3>

                        Recent Products

                    </h3>

                </div>



                @if (Model.Products.Any())
                {

                    <div class="product-list">

                        @foreach (var item in Model.RecentProducts)
                        {

                            <div class="product-item">

                                <div class="product-icon">

                                    <i class="ri-shirt-line"></i>

                                </div>

                                <div class="product-info">

                                    <h4>

                                        @item.ProductName

                                    </h4>

                                    <span>

                                        @item.Category

                                    </span>

                                </div>

                                <div class="product-stock">

                                    @item.Stock

                                </div>

                            </div>

                        }

                    </div>

                }
                else
                {

                    <div class="empty-box">

                        <i class="ri-inbox-archive-line"></i>

                        <h4>

                            No Products Found

                        </h4>

                        <p>

                            Products added from SQL Server will automatically appear here.

                        </p>

                    </div>

                }

            </div>

        </div>



        <!-- RIGHT -->

        <div class="right-column">



            <div class="glass-card action-card">

                <h3>

                    Quick Actions

                </h3>

                <a href="@Url.Action("Create","Product")" class="btn-primary">
                    Add Product
                </a>

                <a href="@Url.Action("Create","Order")" class="btn-primary">
                    Create Order
                </a>

                <a href="@Url.Action("Index","Report")" class="btn-primary">
                    View Reports
                </a>
                <a href="@Url.Action("Index","Settings")" class="btn-primary">
                    Settings
                </a>
            </div>



            <div class="glass-card">

                <h3>

                    Low Stock

                </h3>

                @if (Model.RecentProducts.Any(x => x.Stock <= 5))
                {
                    foreach (var item in Model.Products.Where(x => x.Stock <= 5))
                    {
                        <p>
                            <strong>@item.ProductName</strong> - Stock : @item.Stock
                        </p>
                    }
                }
                else
                {
                    <p>No Low Stock Products.</p>
                }

            </div>

            <div class="glass-card">

                <div class="card-header">

                    <h3>Recent Activity</h3>

                    <i class="ri-history-line"></i>

                </div>

                <div class="activity-list">

                    <div class="activity-item">
                        ✔ Products Updated
                    </div>

                    <div class="activity-item">
                        ✔ Orders Managed
                    </div>

                    <div class="activity-item">
                        ✔ Reports Generated
                    </div>

                    <div class="activity-item">
                        ✔ Inventory Synced
                    </div>

                </div>

            </div>



        </div>

    </section>
    <div class="glass-card" style="margin-top:30px;">

        <div class="card-header">

            <h3>Recent Orders</h3>

        </div>

        <table class="product-table">

            <thead>

                <tr>

                    <th>Customer</th>
                    <th>Product</th>
                    <th>Total</th>
                    <th>Status</th>

                </tr>

            </thead>

            <tbody>

                @if (Model.RecentOrders.Any())
                {
                    foreach (var item in Model.RecentOrders)
                    {
                        <tr>

                            <td>@item.CustomerName</td>

                            <td>@item.ProductName</td>

                            <td>₹@item.TotalAmount</td>

                            <td>

                                @if (item.Status == "Pending")
                                {
                                    <span class="stock-low">@item.Status</span>
                                }
                                else if (item.Status == "Completed")
                                {
                                    <span class="stock-ok">@item.Status</span>
                                }
                                else if (item.Status == "Processing")
                                {
                                    <span class="category-badge">@item.Status</span>
                                }
                                else
                                {
                                    <span class="stock-low">@item.Status</span>
                                }

                            </td>

                        </tr>
                    }
                }

            </tbody>

        </table>

    </div>
</div>
<footer style="text-align:center;padding:20px;color:#777;">

    © 2026 Atelier OS | Clothing ERP

</footer>
@section scripts{

    <script src="~/Scripts/dashboard.js"></script>

}
