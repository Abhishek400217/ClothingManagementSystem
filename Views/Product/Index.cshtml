@model IEnumerable<ClotheManagementSystem.Models.Product>

<div class="page-title">

    <div>

        <span class="hero-badge">
            PRODUCT MANAGEMENT
        </span>

        <h1>Products</h1>

        <p>
            Manage inventory, stock and product catalogue.
        </p>

    </div>

</div>


<div class="glass-card">

    <div class="table-header">

        @using (Html.BeginForm("Index", "Product", FormMethod.Get, new { @class = "search-form" }))
        {
            <div class="search-box">

                <input type="text"
                       name="search"
                       class="search-input"
                       placeholder="Search Product..."
                       value="@Request["search"]"
                       onkeyup="autoSearch(this)" />

                <button type="submit" class="search-btn">

                    <i class="ri-search-2-line"></i>

                </button>

            </div>
        }

        <a href="@Url.Action("Create","Product")"
           class="btn-primary">

            <i class="ri-add-line"></i>

            Add Product

        </a>

    </div>

    <table class="product-table">

        <thead>

            <tr>

                <th>ID</th>

                <th>Image</th>

                <th>Name</th>

                <th>Category</th>

                <th>Price</th>

                <th>Stock</th>

                <th>Action</th>

            </tr>

        </thead>

        <tbody>

            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <tr>

                        <td>@item.ProductId</td>

                        <td>
                             <img src="@(string.IsNullOrEmpty(item.ImageUrl)
                                            ? "https://picsum.photos/120?random=" + item.ProductId
                                            : item.ImageUrl)"
                                 width="80"
                                 height="80"
                                 style="border-radius:12px;object-fit:cover;" />
                        </td>

                        <td>@item.ProductName</td>

                        <td>

                            <span class="category-badge">

                                @item.Category

                            </span>

                        </td>

                        <td>₹@item.Price</td>

                        <td>

                            @if (item.Stock <= 5)
                            {
                                <span class="stock-low">@item.Stock</span>
                            }
                            else
                            {
                                <span class="stock-ok">@item.Stock</span>
                            }

                        </td>

                        <td>

                            <a href="@Url.Action("Edit","Product",
        new { id=item.ProductId })"
                               class="btn-edit">

                                <i class="ri-pencil-line"></i>

                            </a>

                            <a href="@Url.Action("Delete","Product",
        new { id=item.ProductId })"
                               class="btn-delete"
                               onclick="return confirm('Are you sure you want to delete this product?');">

                                <i class="ri-delete-bin-6-line"></i>

                            </a>

                        </td>

                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="7" style="text-align:center;padding:40px;">
                        <div style="padding:40px;text-align:center;">

                            <i class="ri-inbox-archive-line"
                               style="font-size:50px;color:#94a3b8;"></i>

                            <h3>No Products Found</h3>

                            <p>Add your first product to start inventory management.</p>

                        </div>
                    </td>
                </tr>
            }

        </tbody>

    </table>

</div>

@if (TempData["Success"] != null)
{
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>

                    let timer;

            function autoSearch(input){

                clearTimeout(timer);

                timer = setTimeout(function(){

                    if(input.value.trim()=="")
                        window.location='/Product';
                    else
                        input.form.submit();

                },300);
            }

}

        Swal.fire({
            icon: 'success',
            title: '@TempData["Success"]',
            showConfirmButton: false,
            timer: 1800
        });
    </script>
}
