@{
    ViewBag.Title = "Settings";
}

<div class="page-title">

    <div>

        <span class="hero-badge">
            SYSTEM SETTINGS
        </span>

        <h1>Settings</h1>

        <p>Application & Store Information</p>

    </div>

</div>

<div class="glass-card">

    <h3 style="margin-bottom:20px;">
        Store Information
    </h3>

    <div class="form-grid">

        <div class="form-group">
            <label>Store Name</label>
            <input class="form-control" value="Atelier Fashion Store" readonly />
        </div>

        <div class="form-group">
            <label>Owner Name</label>
            <input class="form-control" value="Admin" readonly />
        </div>

        <div class="form-group">
            <label>Email</label>
            <input class="form-control" value="admin@atelier.com" readonly />
        </div>

        <div class="form-group">
            <label>Phone</label>
            <input class="form-control" value="+91 9876543210" readonly />
        </div>

        <div class="form-group full">
            <label>Address</label>
            <textarea class="form-control" rows="3" readonly>Nagpur, Maharashtra, India</textarea>
        </div>

    </div>

</div>

<br />

<div class="glass-card">

    <h3 style="margin-bottom:20px;">
        System Information
    </h3>

    <table class="product-table">

        <tr>
            <td>Application</td>
            <td>Atelier OS Inventory Management System</td>
        </tr>

        <tr>
            <td>Version</td>
            <td>1.0</td>
        </tr>

        <tr>
            <td>Framework</td>
            <td>ASP.NET MVC 5 (.NET Framework)</td>
        </tr>

        <tr>
            <td>Database</td>
            <td>Microsoft SQL Server</td>
        </tr>

        <tr>
            <td>Theme</td>
            <td>Premium Light</td>
        </tr>

        <tr>
            <td>Developer</td>
            <td>Abhishek Karande</td>
        </tr>

    </table>

</div>

<br />

<div class="glass-card">

    <h3 style="margin-bottom:20px;">
        Account Information
    </h3>

    <table class="product-table">

        <tr>
            <td>Username</td>
            <td>Admin</td>
        </tr>

        <tr>
            <td>Role</td>
            <td>Administrator</td>
        </tr>

        <tr>
            <td>Status</td>
            <td><span class="stock-ok">Active</span></td>
        </tr>

    </table>

</div>